rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    function myUserDocPath() {
      return /databases/$(database)/documents/users/$(uid());
    }

    function myUserDocExists() {
      return signedIn() && exists(myUserDocPath());
    }

    function myUserDoc() {
      return get(myUserDocPath());
    }

    function myRole() {
      return myUserDocExists() ? myUserDoc().data.role : null;
    }

    function myInstitutionId() {
      return myUserDocExists() ? myUserDoc().data.institutionId : null;
    }

    function myApprovalStatus() {
      return myUserDocExists() ? myUserDoc().data.approvalStatus : null;
    }

    function isAdmin() {
      return signedIn() && myRole() == 'hospital_admin';
    }

    function isPatient() {
      return signedIn() && myRole() == 'patient';
    }

    function isParent() {
      return signedIn() && myRole() == 'parent';
    }

    function isDoctor() {
      return signedIn() && myRole() == 'doctor';
    }

    function isNurse() {
      return signedIn() && myRole() == 'nurse';
    }

    function isStaff() {
      return signedIn() && (
        myRole() == 'staff' ||
        myRole() == 'support_staff'
      );
    }

    function isMedicalStaff() {
      return signedIn() && (
        isDoctor() ||
        isNurse() ||
        isStaff()
      );
    }

    function isApprovedStaff() {
      return isMedicalStaff() && myApprovalStatus() == 'approved';
    }

    function sameInstitution(institutionId) {
      return signedIn() &&
        myInstitutionId() != null &&
        institutionId != null &&
        myInstitutionId() == institutionId;
    }

    function parentLinkedToPatient(patientId) {
      return signedIn() &&
        exists(/databases/$(database)/documents/care_links/$(uid() + "_" + patientId));
    }

    function patientBelongsToMyInstitution(patientId) {
      return signedIn() &&
        exists(/databases/$(database)/documents/users/$(patientId)) &&
        get(/databases/$(database)/documents/users/$(patientId)).data.institutionId == myInstitutionId();
    }

    function canReadPatientData(patientId) {
      return signedIn() && (
        uid() == patientId ||
        parentLinkedToPatient(patientId) ||
        (isAdmin() && patientBelongsToMyInstitution(patientId)) ||
        (isApprovedStaff() && patientBelongsToMyInstitution(patientId))
      );
    }

    function canWritePatientClinicalData(patientId) {
      return signedIn() && (
        uid() == patientId ||
        (isAdmin() && patientBelongsToMyInstitution(patientId)) ||
        (isApprovedStaff() && patientBelongsToMyInstitution(patientId))
      );
    }

    // institutions
    match /institutions/{hospitalId} {
      allow read: if signedIn();

      allow create: if signedIn()
        && request.resource.data.adminUid == uid()
        && request.resource.data.hospitalId == hospitalId;

      allow update: if signedIn() && (
        resource.data.adminUid == uid() ||
        (
          isAdmin() &&
          sameInstitution(hospitalId) &&
          resource.data.adminUid == uid()
        )
      );

      allow delete: if false;
    }

    // users
    match /users/{userId} {
      allow read: if signedIn() && (
        uid() == userId ||
        parentLinkedToPatient(userId) ||
        (
          isAdmin() &&
          resource.data.institutionId != null &&
          sameInstitution(resource.data.institutionId)
        ) ||
        (
          isApprovedStaff() &&
          resource.data.institutionId != null &&
          sameInstitution(resource.data.institutionId)
        )
      );

      allow create: if signedIn() && uid() == userId;

      allow update: if signedIn() && (
        (
          uid() == userId &&
          (
            !exists(/databases/$(database)/documents/users/$(userId)) ||
            request.resource.data.uid == resource.data.uid
          )
        ) ||
        (
          isAdmin() &&
          resource.data.institutionId != null &&
          sameInstitution(resource.data.institutionId) &&
          (
            resource.data.role == 'doctor' ||
            resource.data.role == 'nurse' ||
            resource.data.role == 'staff' ||
            resource.data.role == 'support_staff'
          ) &&
          request.resource.data.role == resource.data.role &&
          request.resource.data.institutionId == resource.data.institutionId
        )
      );

      allow delete: if signedIn() && uid() == userId;
    }

    // staff requests
    match /staff_requests/{requestId} {
      allow create: if signedIn()
        && requestId == uid()
        && request.resource.data.uid == uid();

      allow read: if signedIn() && (
        resource.data.uid == uid() ||
        (
          isAdmin() &&
          resource.data.institutionId != null &&
          sameInstitution(resource.data.institutionId)
        )
      );

      allow update: if signedIn() && (
        resource.data.uid == uid() ||
        (
          isAdmin() &&
          resource.data.institutionId != null &&
          sameInstitution(resource.data.institutionId)
        )
      );

      allow delete: if signedIn() && (
        resource.data.uid == uid() ||
        (
          isAdmin() &&
          resource.data.institutionId != null &&
          sameInstitution(resource.data.institutionId)
        )
      );
    }

    // departments
    match /departments/{docId} {
      allow read: if signedIn() && (
        (resource.data.institutionId != null && sameInstitution(resource.data.institutionId)) ||
        isAdmin() ||
        isApprovedStaff()
      );

      allow create, update: if signedIn() && (
        isAdmin() &&
        request.resource.data.institutionId != null &&
        sameInstitution(request.resource.data.institutionId)
      );

      allow delete: if signedIn() && (
        isAdmin() &&
        resource.data.institutionId != null &&
        sameInstitution(resource.data.institutionId)
      );
    }

    // dispatch dashboard
    match /dispatch_cases/{docId} {
      allow read: if signedIn() && (
        (resource.data.institutionId != null && sameInstitution(resource.data.institutionId)) ||
        isAdmin() ||
        isApprovedStaff()
      );

      allow create, update: if signedIn() && (
        (
          isAdmin() ||
          isApprovedStaff()
        ) &&
        request.resource.data.institutionId != null &&
        sameInstitution(request.resource.data.institutionId)
      );

      allow delete: if signedIn() && (
        isAdmin() &&
        resource.data.institutionId != null &&
        sameInstitution(resource.data.institutionId)
      );
    }

    // emergency queue
    match /emergency_queue/{docId} {
      allow read: if signedIn() && (
        (resource.data.institutionId != null && sameInstitution(resource.data.institutionId)) ||
        isAdmin() ||
        isApprovedStaff()
      );

      allow create, update: if signedIn() && (
        (
          isAdmin() ||
          isApprovedStaff()
        ) &&
        request.resource.data.institutionId != null &&
        sameInstitution(request.resource.data.institutionId)
      );

      allow delete: if signedIn() && (
        isAdmin() &&
        resource.data.institutionId != null &&
        sameInstitution(resource.data.institutionId)
      );
    }

    // alternative names if your screens use different collection names
    match /dispatches/{docId} {
      allow read: if signedIn();
      allow create, update, delete: if signedIn() && isAdmin();
    }

    match /emergency_cases/{docId} {
      allow read: if signedIn();
      allow create, update, delete: if signedIn() && (isAdmin() || isApprovedStaff());
    }

    match /care_links/{linkId} {
      allow create: if signedIn() && (
        request.resource.data.patientId == uid() ||
        request.resource.data.linkedUserId == uid() ||
        (
          isAdmin() &&
          request.resource.data.institutionId != null &&
          sameInstitution(request.resource.data.institutionId)
        )
      );

      allow read: if signedIn() && (
        resource.data.patientId == uid() ||
        resource.data.linkedUserId == uid() ||
        (
          isAdmin() &&
          resource.data.institutionId != null &&
          sameInstitution(resource.data.institutionId)
        )
      );

      allow update: if signedIn() && (
        resource.data.patientId == uid() ||
        resource.data.linkedUserId == uid() ||
        (
          isAdmin() &&
          resource.data.institutionId != null &&
          sameInstitution(resource.data.institutionId)
        )
      );

      allow delete: if signedIn() && (
        resource.data.patientId == uid() ||
        resource.data.linkedUserId == uid() ||
        (
          isAdmin() &&
          resource.data.institutionId != null &&
          sameInstitution(resource.data.institutionId)
        )
      );
    }

    match /users/{userId}/vitals/{vitalId} {
      allow read: if canReadPatientData(userId);
      allow create, update: if canWritePatientClinicalData(userId);
      allow delete: if uid() == userId || isAdmin();
    }

    match /users/{userId}/alerts/{alertId} {
      allow read: if canReadPatientData(userId);
      allow create, update: if canWritePatientClinicalData(userId);
      allow delete: if uid() == userId || isAdmin();
    }

    match /users/{userId}/medications/{medId} {
      allow read: if canReadPatientData(userId);
      allow create, update: if signedIn() && (
        uid() == userId ||
        (isDoctor() && patientBelongsToMyInstitution(userId)) ||
        (isNurse() && patientBelongsToMyInstitution(userId)) ||
        (isAdmin() && patientBelongsToMyInstitution(userId))
      );
      allow delete: if signedIn() && (
        (isDoctor() && patientBelongsToMyInstitution(userId)) ||
        (isAdmin() && patientBelongsToMyInstitution(userId))
      );
    }

    match /users/{userId}/meds/{medId} {
      allow read: if canReadPatientData(userId);
      allow create, update: if signedIn() && (
        uid() == userId ||
        (isDoctor() && patientBelongsToMyInstitution(userId)) ||
        (isNurse() && patientBelongsToMyInstitution(userId)) ||
        (isAdmin() && patientBelongsToMyInstitution(userId))
      );
      allow delete: if signedIn() && (
        (isDoctor() && patientBelongsToMyInstitution(userId)) ||
        (isAdmin() && patientBelongsToMyInstitution(userId))
      );
    }

    match /users/{userId}/moods/{moodId} {
      allow read: if canReadPatientData(userId);
      allow create, update: if uid() == userId;
      allow delete: if uid() == userId || isAdmin();
    }

    match /users/{userId}/mood_logs/{docId} {
      allow read: if canReadPatientData(userId);
      allow create, update: if uid() == userId;
      allow delete: if uid() == userId || isAdmin();
    }

    match /users/{userId}/wellness_logs/{docId} {
      allow read: if canReadPatientData(userId);
      allow create, update: if uid() == userId;
      allow delete: if uid() == userId || isAdmin();
    }

    match /users/{userId}/reports/{reportId} {
      allow read: if canReadPatientData(userId);
      allow create, update: if signedIn() && (
        uid() == userId ||
        (isDoctor() && patientBelongsToMyInstitution(userId)) ||
        (isNurse() && patientBelongsToMyInstitution(userId)) ||
        (isAdmin() && patientBelongsToMyInstitution(userId))
      );
      allow delete: if signedIn() && (
        (isDoctor() && patientBelongsToMyInstitution(userId)) ||
        (isAdmin() && patientBelongsToMyInstitution(userId))
      );
    }

    match /users/{userId}/doctor_notes/{noteId} {
      allow read: if canReadPatientData(userId);
      allow create, update: if signedIn() && (
        (isDoctor() && patientBelongsToMyInstitution(userId)) ||
        (isAdmin() && patientBelongsToMyInstitution(userId))
      );
      allow delete: if signedIn() && (
        (isDoctor() && patientBelongsToMyInstitution(userId)) ||
        (isAdmin() && patientBelongsToMyInstitution(userId))
      );
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}