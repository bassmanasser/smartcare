rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    function userDocPath(userId) {
      return /databases/$(database)/documents/users/$(userId);
    }

    function myUserDocPath() {
      return userDocPath(uid());
    }

    function myUserDocExists() {
      return signedIn() && exists(myUserDocPath());
    }

    function myUserDoc() {
      return get(myUserDocPath());
    }

    function myRole() {
      return myUserDocExists() ? myUserDoc().data.role : null;
    }

    function myInstitutionId() {
      return myUserDocExists() ? myUserDoc().data.institutionId : null;
    }

    function myApprovalStatus() {
      return myUserDocExists() ? myUserDoc().data.approvalStatus : null;
    }

    function isAdmin() {
      return signedIn() && myRole() == 'hospital_admin';
    }

    function isPatient() {
      return signedIn() && myRole() == 'patient';
    }

    function isParent() {
      return signedIn() && myRole() == 'parent';
    }

    function isDoctor() {
      return signedIn() && myRole() == 'doctor';
    }

    function isNurse() {
      return signedIn() && myRole() == 'nurse';
    }

    function isStaff() {
      return signedIn() && (
        myRole() == 'staff' ||
        myRole() == 'support_staff'
      );
    }

    function isMedicalStaff() {
      return signedIn() && (isDoctor() || isNurse() || isStaff());
    }

    function isApprovedStaff() {
      return isMedicalStaff() && myApprovalStatus() == 'approved';
    }

    function sameInstitution(institutionId) {
      return signedIn() &&
        institutionId != null &&
        myInstitutionId() != null &&
        myInstitutionId() == institutionId;
    }

    function patientDocExists(patientId) {
      return exists(userDocPath(patientId));
    }

    function patientInstitutionId(patientId) {
      return patientDocExists(patientId)
        ? get(userDocPath(patientId)).data.institutionId
        : null;
    }

    function patientBelongsToMyInstitution(patientId) {
      return signedIn() &&
        patientInstitutionId(patientId) != null &&
        patientInstitutionId(patientId) == myInstitutionId();
    }

    function parentLinkedToPatient(patientId) {
      return signedIn() &&
        exists(/databases/$(database)/documents/care_links/$(uid() + "_" + patientId));
    }

    function canReadPatientData(patientId) {
      return signedIn() && (
        uid() == patientId ||
        parentLinkedToPatient(patientId) ||
        (isAdmin() && patientBelongsToMyInstitution(patientId)) ||
        (isApprovedStaff() && patientBelongsToMyInstitution(patientId))
      );
    }

    function canWritePatientProfile(patientId) {
      return signedIn() && uid() == patientId;
    }

    function canWritePatientClinicalData(patientId) {
      return signedIn() && (
        uid() == patientId ||
        (isAdmin() && patientBelongsToMyInstitution(patientId)) ||
        (isApprovedStaff() && patientBelongsToMyInstitution(patientId))
      );
    }

    function allowedSelfUserFieldsOnly() {
      return request.resource.data.role == resource.data.role &&
        request.resource.data.institutionId == resource.data.institutionId &&
        request.resource.data.approvalStatus == resource.data.approvalStatus;
    }

    match /institutions/{hospitalId} {
      allow read: if signedIn();

      allow create: if signedIn()
        && request.resource.data.adminUid == uid()
        && request.resource.data.hospitalId == hospitalId;

      allow update: if signedIn() && (
        resource.data.adminUid == uid() ||
        (isAdmin() && sameInstitution(hospitalId) && resource.data.adminUid == uid())
      );

      allow delete: if false;
    }

    match /users/{userId} {
      allow read: if signedIn() && (
        uid() == userId ||
        parentLinkedToPatient(userId) ||
        (
          isAdmin() &&
          resource.data.institutionId != null &&
          sameInstitution(resource.data.institutionId)
        ) ||
        (
          isApprovedStaff() &&
          resource.data.institutionId != null &&
          sameInstitution(resource.data.institutionId)
        )
      );

      allow create: if signedIn()
        && uid() == userId
        && request.resource.data.uid == userId;

      allow update: if signedIn() && (
        (
          uid() == userId &&
          resource != null &&
          allowedSelfUserFieldsOnly()
        ) ||
        (
          isAdmin() &&
          resource.data.institutionId != null &&
          sameInstitution(resource.data.institutionId) &&
          (
            resource.data.role == 'doctor' ||
            resource.data.role == 'nurse' ||
            resource.data.role == 'staff' ||
            resource.data.role == 'support_staff'
          ) &&
          request.resource.data.role == resource.data.role &&
          request.resource.data.institutionId == resource.data.institutionId
        )
      );

      allow delete: if signedIn() && uid() == userId;
    }

    match /staff_requests/{requestId} {
      allow create: if signedIn()
        && requestId == uid()
        && request.resource.data.uid == uid();

      allow read, update, delete: if signedIn() && (
        resource.data.uid == uid() ||
        (
          isAdmin() &&
          resource.data.institutionId != null &&
          sameInstitution(resource.data.institutionId)
        )
      );
    }

    match /departments/{docId} {
      allow read: if signedIn() && (
        (resource.data.institutionId != null && sameInstitution(resource.data.institutionId)) ||
        isAdmin() ||
        isApprovedStaff()
      );

      allow create, update: if signedIn() &&
        isAdmin() &&
        request.resource.data.institutionId != null &&
        sameInstitution(request.resource.data.institutionId);

      allow delete: if signedIn() &&
        isAdmin() &&
        resource.data.institutionId != null &&
        sameInstitution(resource.data.institutionId);
    }

    match /dispatch_cases/{docId} {
      allow read: if signedIn() && (
        canReadPatientData(resource.data.patientId) ||
        (
          resource.data.institutionId != null &&
          sameInstitution(resource.data.institutionId) &&
          (isAdmin() || isApprovedStaff())
        )
      );

      allow create, update: if signedIn() && (
        (
          isAdmin() ||
          isApprovedStaff()
        ) &&
        request.resource.data.institutionId != null &&
        sameInstitution(request.resource.data.institutionId)
      );

      allow delete: if signedIn() &&
        isAdmin() &&
        resource.data.institutionId != null &&
        sameInstitution(resource.data.institutionId);
    }

    match /emergency_queue/{docId} {
      allow read: if signedIn() && (
        (
          resource.data.institutionId != null &&
          sameInstitution(resource.data.institutionId)
        ) &&
        (isAdmin() || isApprovedStaff())
      );

      allow create, update: if signedIn() &&
        request.resource.data.institutionId != null &&
        sameInstitution(request.resource.data.institutionId) &&
        (isAdmin() || isApprovedStaff());

      allow delete: if signedIn() &&
        resource.data.institutionId != null &&
        sameInstitution(resource.data.institutionId) &&
        isAdmin();
    }

    match /alerts/{alertId} {
      allow read: if signedIn() && (
        canReadPatientData(resource.data.patientId) ||
        (
          resource.data.institutionId != null &&
          sameInstitution(resource.data.institutionId) &&
          (isAdmin() || isApprovedStaff())
        )
      );

      allow create: if false;
      allow update, delete: if false;
    }

    match /care_links/{linkId} {
      allow read: if signedIn() && (
        resource.data.patientId == uid() ||
        resource.data.linkedUserId == uid() ||
        (isAdmin() && resource.data.institutionId != null && sameInstitution(resource.data.institutionId))
      );

      allow create: if signedIn();

      allow update, delete: if signedIn() && (
        resource.data.patientId == uid() ||
        resource.data.linkedUserId == uid() ||
        (isAdmin() && resource.data.institutionId != null && sameInstitution(resource.data.institutionId))
      );
    }

    match /users/{userId}/vitals/{vitalId} {
      allow read: if canReadPatientData(userId);
      allow create: if canWritePatientClinicalData(userId);
      allow update, delete: if canWritePatientClinicalData(userId);
    }

    match /users/{userId}/alerts/{alertId} {
      allow read: if canReadPatientData(userId);
      allow create: if false;
      allow update, delete: if false;
    }

    match /users/{userId}/assessments/{docId} {
      allow read: if canReadPatientData(userId);
      allow create, update, delete: if canWritePatientClinicalData(userId);
    }

    match /users/{userId}/dispatches/{docId} {
      allow read: if canReadPatientData(userId);
      allow create, update, delete: if canWritePatientClinicalData(userId);
    }

    match /users/{userId}/timeline/{docId} {
      allow read: if canReadPatientData(userId);
      allow create, update, delete: if canWritePatientClinicalData(userId);
    }

    match /users/{userId}/doctor_notes/{noteId} {
      allow read: if canReadPatientData(userId);
      allow create, update, delete: if (
        isAdmin() && patientBelongsToMyInstitution(userId)
      ) || (
        isApprovedStaff() && patientBelongsToMyInstitution(userId)
      );
    }

    match /users/{userId}/{subCollection}/{docId} {
      allow read: if canReadPatientData(userId);
      allow create, update, delete: if canWritePatientClinicalData(userId);
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
